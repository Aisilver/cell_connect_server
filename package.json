{
  "name": "dominon_cell_server",
  "version": "1.0.0",
  "description": "The server for dominon cell",
  "main": "init.js",
  "scripts": {
    "prebuild-dev": "powershell -ExecutionPolicy Bypass -File ./scripts/fetch-types.ps1",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:main:gen": "npm run typeorm -- migration:generate src/migrations/main/new-main-migration -d src/datasources/main-entities-ds/datasource/datasource.migration.ts",
    "typeorm:main:run": "npm run typeorm -- migration:run -d dist/datasources/main-entities-ds/datasource/datasource.run.js",
    "typeorm:miscellaneous:gen": "npm run typeorm -- migration:generate src/migrations/miscellaneous/new-miscellaneous-migration -d src/datasources/miscellaneous-entites-ds/datasource/datasource.migration.ts",
    "typeorm:miscellaneous:run": "npm run typeorm -- migration:run -d dist/datasources/miscellaneous-entites-ds/datasource/datasource.run.js",
    "migration:gen": "npm run typeorm:main:gen & npm run typeorm:miscellaneous:gen",
    "migration:run": "npm run typeorm:main:run & npm run typeorm:miscellaneous:run",
    "build": "tsc",
    "watch": "npm run prebuild-dev && tsc --watch",
    "start": "npm run migration:run && node dist/init.js",
    "dev": "nodemon dist/init.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emmyoftech/dominon_cell_server.git"
  },
  "author": "emmyoftech",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/emmyoftech/dominon_cell_server/issues"
  },
  "homepage": "https://github.com/emmyoftech/dominon_cell_server#readme",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.2",
    "install": "^0.13.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@supabase/supabase-js": "^2.75.0",
    "@types/cookie-parser": "^1.4.10",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "colorette": "^2.0.20",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "file-type": "^21.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.8.1",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.9",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.6.0",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27"
  }
}
